# Resend
# Production cutover: use the dedicated iProduce Resend project key.
RESEND_API_KEY=
# Keep onboarding@resend.dev only for local/preview testing before domain DNS is verified.
# Production must use the verified iProduce sender, for example:
# EMAIL_FROM="iProduce Africa <info@iproduceafrica.com>"
EMAIL_FROM="iProduce Africa <onboarding@resend.dev>"

# Internal Resend notification inboxes (defaults to info@ until client confirms routing).
# NEWSLETTER_TO_EMAIL is rollback-only and can be removed after the Mailchimp
# production smoke test passes.
CONTACT_TO_EMAIL=info@iproduceafrica.com
PARTNERS_TO_EMAIL=info@iproduceafrica.com
COMMUNITY_TO_EMAIL=info@iproduceafrica.com
ACADEMY_TO_EMAIL=info@iproduceafrica.com
NEWSLETTER_TO_EMAIL=info@iproduceafrica.com

# Mailchimp Marketing — newsletter subscribers only
# Keep all three values server-only. Never expose them through NEXT_PUBLIC_*.
# Production should use the client-owned iProduce Africa Mailchimp account.
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_AUDIENCE_ID=

# Cloudflare Turnstile
# Production: use keys from https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Local dev (optional): Cloudflare test keys always pass verification
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Upstash Redis (rate limiting — required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Local dev: rate limits are skipped unless you opt in
# ENABLE_DEV_RATE_LIMITS=true
# Vercel injects VERCEL_ENV automatically; do not add it manually.

# Optional — public site URL for metadata, canonical links, and email CTAs.
# Production: set to the active public origin. Until iproduceafrica.com is live
# on Vercel, use the production Vercel deployment:
NEXT_PUBLIC_SITE_URL=https://iproduce-africa.vercel.app

# Optional — absolute origin for email logo images (public/brand/email-logo.png).
# Match NEXT_PUBLIC_SITE_URL until the custom domain is cut over, then switch
# both to https://iproduceafrica.com.
EMAIL_ASSETS_BASE_URL=https://iproduce-africa.vercel.app

# Sanity CMS — use development locally/for preview and production only in the
# production deployment. See docs/cms-migration-spec.md for the ownership map.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=development
# Required for public fetches — the dataset is private. Prefer this
# read-scoped token in every deployed environment (Vercel preview/production);
# SANITY_API_WRITE_TOKEN is only a local-dev fallback and should stay
# migration-only where possible.
SANITY_API_READ_TOKEN=
# Used by scripts/migrate-academy-to-sanity.ts; also read as a fallback by
# lib/sanity/client.ts if SANITY_API_READ_TOKEN is unset.
SANITY_API_WRITE_TOKEN=
# Webhook signature verification for app/api/revalidate/route.ts
SANITY_REVALIDATE_SECRET=
